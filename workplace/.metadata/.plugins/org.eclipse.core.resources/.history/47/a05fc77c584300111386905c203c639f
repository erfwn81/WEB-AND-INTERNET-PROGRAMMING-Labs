/* =====================================================
   CS3220 Lab 11 - GuestBook Application Styles
   Purple-blue theme matching lab screenshots
   ===================================================== */

/* Body: full-page gradient background */
body {
    background: linear-gradient(160deg, #5c6bc0 0%, #7986cb 50%, #9fa8da 100%);
    min-height: 100vh;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    padding: 20px 0;
    color: #fff;
}

/* ---- Page Wrapper (form/content container) ---- */
.page-wrapper {
    background-color: rgba(63, 70, 150, 0.82);
    border-radius: 6px;
    padding: 35px 40px;
    max-width: 680px;
    margin: 40px auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* Wide wrapper for the guestbook table */
.page-wrapper-wide {
    background-color: rgba(63, 70, 150, 0.82);
    border-radius: 6px;
    padding: 35px 40px;
    max-width: 900px;
    margin: 40px auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* ---- Headings ---- */
h2 {
    text-align: center;
    color: #ffffff;
    font-size: 2rem;
    margin-bottom: 25px;
    font-weight: normal;
}

/* ---- Form Layout ---- */
.form-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 10px;
}

.form-table tr td {
    padding: 8px 6px;
    vertical-align: middle;
}

/* Label column */
.form-table tr td:first-child {
    color: #c5d4f8;
    font-size: 0.95rem;
    width: 110px;
    font-weight: bold;
}

/* Input fields */
.form-table input[type="text"],
.form-table input[type="email"],
.form-table input[type="password"] {
    border: 2px solid #6f8fe0;
    padding: 6px 10px;
    background-color: #ffffff;
    color: #333;
    font-size: 0.9rem;
    width: 220px;
    outline: none;
    border-radius: 2px;
}

.form-table input:focus {
    border-color: #3d68d8;
    box-shadow: 0 0 4px rgba(61, 104, 216, 0.6);
}

/* ---- Textarea (for messages) ---- */
textarea.msg-area {
    width: 100%;
    height: 300px;
    resize: vertical;
    padding: 10px;
    border: 2px solid #6f8fe0;
    border-radius: 2px;
    font-size: 0.95rem;
    color: #333;
    background: #fff;
    box-sizing: border-box;
    outline: none;
}

textarea.msg-area:focus {
    border-color: #3d68d8;
}

/* ---- Validation Error Messages ---- */
.field-error {
    color: #ff4444;
    font-size: 0.85rem;
    font-weight: bold;
    margin-left: 8px;
}

.form-error {
    color: #ff4444;
    font-weight: bold;
    text-align: center;
    margin: 10px 0 5px;
    font-size: 0.9rem;
}

/* ---- Buttons ---- */
.btn-blue {
    background-color: #2979ff;
    color: #ffffff;
    border: none;
    padding: 9px 22px;
    font-size: 0.9rem;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    margin: 3px;
    font-weight: 500;
    transition: background-color 0.2s ease;
}

.btn-blue:hover {
    background-color: #1565c0;
    color: #ffffff;
    text-decoration: none;
}

.btn-center {
    text-align: center;
    margin-top: 18px;
}

/* ---- Welcome / Action Row ---- */
.welcome-actions {
    text-align: center;
    margin: 0 0 20px 0;
}

/* ---- GuestBook Table ---- */
.guestbook-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 5px;
    background-color: #ffffff;
}


.guestbook-table thead tr {
    background-color: rgba(40, 50, 120, 0.85);
}

.guestbook-table th {
    padding: 12px 10px;
    text-align: center;
    font-weight: bold;
    font-size: 0.95rem;
    border: none;
}

.guestbook-table tbody tr {
    background-color: rgba(80, 95, 175, 0.45);
    transition: background-color 0.2s ease;
}

/* Row hover effect as required by task 6 */
.guestbook-table tbody tr:hover {
    background-color: rgba(120, 140, 220, 0.7);
}

.guestbook-table td {
    padding: 11px 10px;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    font-size: 0.9rem;
}

/* Name column in a softer blue */
.guestbook-table td.name-col {
    color: #c5d4f8;
    font-weight: 500;
}

/* ---- No Message Text ---- */
.no-message {
    text-align: center;
    font-size: 1.3rem;
    padding: 25px 0 10px;
    color: #dce8ff;
}

/* ---- Delete form inside table cell (remove button margin) ---- */
.delete-form {
    display: inline;
    margin: 0;
    padding: 0;
}
