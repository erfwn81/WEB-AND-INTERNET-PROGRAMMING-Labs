/* =====================================================
   CS3220 Lab 11 - GuestBook Application Styles
   ===================================================== */

body {
    background: linear-gradient(160deg, #5c6bc0 0%, #7986cb 50%, #9fa8da 100%);
    min-height: 100vh;
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    padding: 20px 0;
    color: #fff;
}

/* ---- Page Wrapper (login/register/add/edit forms) ---- */
.page-wrapper {
    background-color: rgba(63, 70, 150, 0.82);
    border-radius: 6px;
    padding: 35px 40px;
    max-width: 680px;
    margin: 40px auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* ---- Wide wrapper for guestbook ---- */
.page-wrapper-wide {
    background-color: rgba(63, 70, 150, 0.82);
    border-radius: 6px;
    padding: 35px 40px;
    max-width: 900px;
    margin: 40px auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

/* ---- Headings ---- */
h2 {
    text-align: center;
    color: #ffffff;
    font-size: 2rem;
    margin-bottom: 25px;
    font-weight: normal;
}

/* ---- Form Layout ---- */
.form-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 10px;
}

.form-table tr td {
    padding: 8px 6px;
    vertical-align: middle;
}

.form-table tr td:first-child {
    color: #c5d4f8;
    font-size: 0.95rem;
    width: 110px;
    font-weight: bold;
}

.form-table input[type="text"],
.form-table input[type="email"],
.form-table input[type="password"] {
    border: 2px solid #6f8fe0;
    padding: 6px 10px;
    background-color: #ffffff;
    color: #333;
    font-size: 0.9rem;
    width: 220px;
    outline: none;
    border-radius: 2px;
}

.form-table input:focus {
    border-color: #3d68d8;
}

/* ---- Textarea ---- */
textarea.msg-area {
    width: 100%;
    height: 300px;
    resize: vertical;
    padding: 10px;
    border: 2px solid #6f8fe0;
    border-radius: 2px;
    font-size: 0.95rem;
    color: #333;
    background: #fff;
    box-sizing: border-box;
    outline: none;
}

/* ---- Validation Errors ---- */
.field-error {
    color: #ff4444;
    font-size: 0.85rem;
    font-weight: bold;
    margin-left: 8px;
}

.form-error {
    color: #ff4444;
    font-weight: bold;
    text-align: center;
    margin: 10px 0 5px;
    font-size: 0.9rem;
}

/* ---- Buttons ---- */
.btn-blue {
    background-color: #2979ff;
    color: #ffffff;
    border: none;
    padding: 9px 22px;
    font-size: 0.9rem;
    border-radius: 4px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    margin: 3px;
    font-weight: 500;
    transition: background-color 0.2s ease;
}

.btn-blue:hover {
    background-color: #1565c0;
    color: #ffffff;
    text-decoration: none;
}

.btn-center {
    text-align: center;
    margin-top: 18px;
}

/* ---- Welcome / Action Row ---- */
.welcome-actions {
    text-align: center;
    margin: 0 0 20px 0;
}

/* ============================================
   GUESTBOOK TABLE - matches lab screenshot
   White rows, alternating, dark text, borders
   ============================================ */

.guestbook-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 5px;
    background-color: #ffffff;
}

/* Header row: dark background, white bold text */
.guestbook-table thead tr {
    background-color: #2c2c3e;
}

.guestbook-table th {
    padding: 12px 10px;
    text-align: center;
    font-weight: bold;
    font-size: 0.95rem;
    color: #ffffff;
    border: 1px solid #444;
}

/* Body rows: white background with dark text */
.guestbook-table tbody tr {
    background-color: #ffffff;
}

/* Alternating row: every even row gets a light gray */
.guestbook-table tbody tr:nth-child(even) {
    background-color: #f2f2f2;
}

/* Hover effect (Task 6) */
.guestbook-table tbody tr:hover {
    background-color: #dce8ff;
}

.guestbook-table td {
    padding: 11px 10px;
    text-align: center;
    border: 1px solid #cccccc;
    font-size: 0.9rem;
    color: #333333;
}

/* Name column */
.guestbook-table td.name-col {
    color: #333333;
    font-weight: 500;
}

/* ---- No Message ---- */
.no-message {
    text-align: center;
    font-size: 1.3rem;
    padding: 25px 0 10px;
    color: #dce8ff;
}

/* ---- Delete form inline ---- */
.delete-form {
    display: inline;
    margin: 0;
    padding: 0;
}